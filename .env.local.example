# ─── NextAuth v5 ─────────────────────────────────────────────────
AUTH_SECRET=your_random_secret_here   # openssl rand -base64 32
AUTH_GITHUB_ID=your_github_oauth_app_id
AUTH_GITHUB_SECRET=your_github_oauth_app_secret

# Admin access — only this GitHub username can sign in to /admin
ADMIN_GITHUB_USERNAME=your_github_username

# ─── Database (Prisma 7 + driver adapters) ───────────────────────
# Switch provider with: pnpm db:use <sqlite|postgresql|mysql>
DATABASE_URL="file:./prisma/dev.db"
# Postgres example: DATABASE_URL="postgresql://user:pass@host:5432/db?schema=public"
# Supabase pooler: DATABASE_URL="postgresql://postgres.[REF]:[PASS]@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
# MySQL example:    DATABASE_URL="mysql://user:pass@host:3306/db"

# ─── Storage (uploads) ───────────────────────────────────────────
# local | s3   (s3 also covers Cloudflare R2, MinIO, Backblaze B2)
STORAGE_PROVIDER=local

# When STORAGE_PROVIDER=s3, configure these:
# STORAGE_BUCKET=my-bucket
# STORAGE_REGION=auto                            # "auto" for R2, "eu-west-1" for AWS
# STORAGE_ACCESS_KEY_ID=...
# STORAGE_SECRET_ACCESS_KEY=...
# STORAGE_ENDPOINT=                              # required for R2/MinIO, omit for AWS
#                                                # R2:    https://<acct>.r2.cloudflarestorage.com
#                                                # MinIO: http://localhost:9000
# STORAGE_PUBLIC_URL=                            # optional CDN/custom domain prefix
#                                                # e.g. https://cdn.slaega.me
# STORAGE_FORCE_PATH_STYLE=false                 # "true" for MinIO
# STORAGE_ACL=public-read                        # or "private" if your bucket policy handles access

# ─── Optional ────────────────────────────────────────────────────
ANTHROPIC_API_KEY=                               # AI-powered CV generation
TELEMETRY_WEBHOOK_URL=
